generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  role         String    @default("CUSTOMER")
  active       Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders        Order[]
  sessions      Session[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([role])
  @@index([phone])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String?
  email     String
  name      String?
  role      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  parentId    String?
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([active, sortOrder])
}

model Product {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  sku               String?   @unique
  categoryId        String?
  shortDescription  String?
  longDescription   String?
  material          String?
  manufacturer      String?
  gender            String?
  basePriceCents    Int
  discountPriceCents Int?
  isRecommended     Boolean   @default(false)
  isFeatured        Boolean   @default(false)
  status            String    @default("draft")
  tags              String?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  category Category?        @relation(fields: [categoryId], references: [id])
  images   ProductImage[]
  variants ProductVariant[]
  items    OrderItem[]

  @@index([status, deletedAt])
  @@index([isRecommended])
  @@index([isFeatured])
  @@index([categoryId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isMain    Boolean  @default(false)
  fileName  String?
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductVariant {
  id                 String    @id @default(cuid())
  productId          String
  size               String?
  color              String?
  sku                String?   @unique
  stockQuantity      Int       @default(0)
  priceOverrideCents Int?
  discountOverrideCents Int?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  items   OrderItem[]

  @@index([productId])
  @@index([size])
  @@index([color])
  @@index([stockQuantity])
}

model Order {
  id            String    @id @default(cuid())
  orderNumber   String    @unique
  userId        String?
  firstName     String
  lastName      String
  phone         String
  email         String?
  locality      String?
  deliveryMethod String
  comment       String?
  internalNotes String?
  status        String    @default("NEW")
  estimatedTotalCents Int
  statusTimeline String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([status, createdAt])
  @@index([phone])
  @@index([firstName, lastName])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  productId      String
  variantId      String
  productName    String
  variantLabel   String?
  sku            String?
  unitPriceCents Int
  quantity       Int
  lineTotalCents Int
  createdAt      DateTime @default(now())

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String?
  audience   String    @default("ADMIN")
  title      String
  message    String
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([audience, readAt])
}

model StoreSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String    @id @default(cuid())
  firstName String
  lastName  String?
  phone     String?
  email     String?
  message   String
  status    String    @default("NEW")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}
